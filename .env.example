# ──────────────────────────────────────────────────────────────────────────────
#  Variables d'environnement — Garage Mendonça
#  Copier ce fichier en .env.local et adapter les valeurs.
# ──────────────────────────────────────────────────────────────────────────────

# UUID du garage actif — doit correspondre à la colonne `id` (UUID) de la table
# `garages` en Supabase. Toutes les FK (vehicles.garage_id, services.garage_id…)
# référencent cet UUID.
# En déploiement mono-garage : définir une seule valeur fixe.
# En déploiement multi-garage : chaque instance Vercel reçoit son propre UUID.
# Exemple avec le garage seed : 00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_GARAGE_ID=00000000-0000-0000-0000-000000000001

# ── Supabase ────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_ENABLED=true   # true = live Supabase | false = données mock
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...    # serveur uniquement, jamais exposé côté client
