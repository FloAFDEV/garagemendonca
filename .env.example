# ──────────────────────────────────────────────────────────────────────────────
#  Variables d'environnement — Garage Mendonça
#  Copier ce fichier en .env.local et adapter les valeurs.
# ──────────────────────────────────────────────────────────────────────────────

# UUID du garage actif — colonne `id` (UUID) de la table `garages` en Supabase.
# Toutes les FK (vehicles.garage_id, services.garage_id…) référencent cet UUID.
# Valeur seed : 00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_GARAGE_ID=00000000-0000-0000-0000-000000000001

# ── Mode d'exécution ───────────────────────────────────────────────────────────
# NEXT_PUBLIC_DEMO_MODE=true   → données statiques (lib/data.ts), aucun appel DB
# NEXT_PUBLIC_DEMO_MODE=false  → Supabase obligatoire (erreur si non configuré)
# Non défini + Supabase absent → auto-bascule en mode démo
NEXT_PUBLIC_DEMO_MODE=false

# ── Supabase ────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_ENABLED=false  # Désactive Supabase même si URL+key présentes
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...    # serveur uniquement, jamais exposé côté client

# ── Analytics & Tracking ───────────────────────────────────────────────────────
#
# ┌─ RÈGLE ABSOLUE ────────────────────────────────────────────────────────────┐
# │  NE PAS configurer GTM_ID et GA_ID simultanément.                         │
# │  Résultat : double tracking (page_view x2, events dupliqués, Ads x2).     │
# │                                                                            │
# │  Choisir UNE des deux stratégies :                                         │
# │                                                                            │
# │  ① GTM seul (RECOMMANDÉ — scalable, sans code)                            │
# │     → GA4 configuré dans GTM (tag "GA4 Configuration")                    │
# │     → pixels Meta, Ads, conversion = ajout dans GTM sans code             │
# │     → A/B tests, événements futurs = GTM sans déploiement                 │
# │     NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX                                        │
# │                                                                            │
# │  ② GA4 direct (minimal, sans GTM)                                         │
# │     → Un seul tag GA4, aucune flexibilité future                          │
# │     → Ajouter un pixel = modifier le code                                 │
# │     NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX                                        │
# │                                                                            │
# │  Si les deux sont définis : GTM prioritaire, GA_ID ignoré + warning dev  │
# └────────────────────────────────────────────────────────────────────────────┘
#
# Laisser les deux commentés en local pour désactiver tout tracking.

# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Consent Mode v2
# true (défaut) = signaux consent envoyés avant GTM/GA
# false = désactiver si aucun tag Google configuré
NEXT_PUBLIC_GOOGLE_CONSENT_MODE=true
