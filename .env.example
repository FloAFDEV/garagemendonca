# ──────────────────────────────────────────────────────────────────────────────
#  Variables d'environnement — Garage Mendonça
#  Copier ce fichier en .env.local et adapter les valeurs.
# ──────────────────────────────────────────────────────────────────────────────

# Identifiant du garage actif (slug).
# Doit correspondre à la colonne `slug` de la table `garages` en Supabase.
# En déploiement mono-garage : une seule valeur, une seule instance.
# En déploiement multi-garage : chaque instance Vercel reçoit son propre slug.
# Exemples :
#   garage-mendonca-dremil
#   garage-dupont-toulouse
NEXT_PUBLIC_GARAGE_ID=garage-mendonca-dremil

# ── Supabase (à ajouter lors de la migration) ──────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # serveur uniquement, jamais exposé côté client
