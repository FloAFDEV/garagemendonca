# ══════════════════════════════════════════════════════════════════════
#  .env.local — Garage Mendonça — Configuration locale / Vercel
#
#  IMPORTANT : Ce fichier ne doit JAMAIS être commité dans le repo.
#  Copier ce fichier en .env.local et compléter les valeurs.
#
#  .env.local est dans .gitignore — vos clés restent sur votre machine.
# ══════════════════════════════════════════════════════════════════════

# ── Identifiant du garage ──────────────────────────────────────────
# UUID de la ligne dans la table `garages` (colonne `id`).
# Valeur seed par défaut : 00000000-0000-0000-0000-000000000001
# En production : remplacer par l'UUID réel généré par Supabase.
NEXT_PUBLIC_GARAGE_ID=00000000-0000-0000-0000-000000000001

# ── Mode d'exécution ───────────────────────────────────────────────
# NEXT_PUBLIC_DEMO_MODE
#   true  → données statiques embarquées, aucun appel Supabase
#   false → Supabase obligatoire (erreur si non configuré)
#   non défini + Supabase absent → auto-bascule en mode démo
NEXT_PUBLIC_DEMO_MODE=false

# ── Supabase ───────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_ENABLED
#   false → désactive Supabase même si URL+key présentes (override)
#   non défini → activé si URL + clé présentes
# NEXT_PUBLIC_SUPABASE_ENABLED=false

# URL de votre projet Supabase
# Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co

# Clé anon (publique) — utilisée côté client pour les lectures RLS
# Supabase Dashboard → Settings → API → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service-role (SECRÈTE) — utilisée côté serveur uniquement (Server Actions)
# Supabase Dashboard → Settings → API → service_role / secret
# NE JAMAIS EXPOSER CÔTÉ CLIENT — jamais de NEXT_PUBLIC_ prefix ici
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Étapes pour connecter Supabase ────────────────────────────────
#
# 1. Créer un projet sur https://supabase.com
# 2. Exécuter supabase/migrations/001_init.sql dans l'éditeur SQL
# 3. (Optionnel) Exécuter supabase/seed.sql pour les données de test
# 4. Créer les buckets Storage :
#      vehicle-images  (public, CDN activé)
#      service-images  (public, CDN activé)
#      garage-logos    (public, CDN activé)
# 5. Copier les clés depuis Dashboard → Settings → API
# 6. Mettre à jour NEXT_PUBLIC_GARAGE_ID avec l'UUID réel du garage
# 7. Sur Vercel : Project Settings → Environment Variables → ajouter les mêmes
#
# ══════════════════════════════════════════════════════════════════════
